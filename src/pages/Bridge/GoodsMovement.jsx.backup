import React, { useState, useMemo } from 'react';
import { Search, Calendar, Package, User, ArrowRight, Eye, Download } from 'lucide-react';
import { useData } from '../../context/DataContext';
import Button from '../../components/Common/Button';
import { exportToCSV } from '../../utils/exportCSV';

const GoodsMovement = () =\u003e {
    const { mutationLogs = [], inboundTransactions = [], addMutationLog, updateInventoryStock } = useData();
const [searchTerm, setSearchTerm] = useState('');
const [selectedGroup, setSelectedGroup] = useState(null);

// Group mutation logs by unique item (pengajuanNumber + itemCode + serialNumber)
const groupedMutations = useMemo(() =\u003e {
    const groups = {};

    mutationLogs.forEach(log =\u003e {
        const key = `${log.pengajuanNumber}-${log.itemCode}-${log.serialNumber || 'no-sn'}`;

        if(!groups[key]) {
            groups[key] = {
                pengajuanNumber: log.pengajuanNumber,
                pengajuanId: log.pengajuanId,
                bcDocumentNumber: log.bcDocumentNumber,
                itemCode: log.itemCode,
                itemName: log.itemName,
                serialNumber: log.serialNumber,
                hsCode: log.hsCode,
                uom: log.uom,
                mutations: [],
                remutations: []
            };
        }

            // Classify as mutation (outbound) or remutation (return to warehouse)
            if(log.destination && log.destination.toLowerCase() !== 'warehouse' && log.destination.toLowerCase() !== 'gudang') {
    groups[key].mutations.push(log);
} else if (log.origin && log.origin.toLowerCase() !== 'warehouse' && log.origin.toLowerCase() !== 'gudang') {
    groups[key].remutations.push(log);
}
        });

// Convert to array and enrich with inbound data
return Object.values(groups).map(group =\u003e {
    // Find corresponding inbound transaction to get initial stock
    const inbound = inboundTransactions
        .flatMap(trans =\u003e trans.items || [])
        .find(item =\u003e 
                    item.itemCode === group.itemCode &&
            item.serialNumber === group.serialNumber
        );

    // Calculate totals
    const totalMutated = group.mutations.reduce((sum, m) =\u003e sum + (m.mutatedQty || 0), 0);
    const totalRemutated = group.remutations.reduce((sum, r) =\u003e sum + (r.mutatedQty || 0), 0);
    const initialStock = inbound?.quantity || group.mutations[0]?.totalStock || 0;
    const currentRemaining = initialStock - totalMutated + totalRemutated;

    return {
        ...group,
        initialStock,
        totalMutated,
        totalRemutated,
        currentRemaining,
        // Take latest dates from mutations/remutations
        lastMutationDate: group.mutations.length \u003e 0? group.mutations[group.mutations.length - 1].date : null,
        lastRemutationDate: group.remutations.length \u003e 0? group.remutations[group.remutations.length - 1].date : null,
        lastMutationTime: group.mutations.length \u003e 0? group.mutations[group.mutations.length - 1].time : null,
        lastPIC: group.mutations.length \u003e 0? group.mutations[group.mutations.length - 1].pic : null,
        destination: group.mutations.length \u003e 0? group.mutations[0].destination : null,
        remarks: group.mutations.length \u003e 0? group.mutations[0].remarks : null
            };
});
    }, [mutationLogs, inboundTransactions]);

// Filter grouped mutations based on search
const filteredLogs = groupedMutations.filter(group =\u003e
        group.pengajuanNumber?.toLowerCase().includes(searchTerm.toLowerCase()) ||
    group.bcDocumentNumber?.toLowerCase().includes(searchTerm.toLowerCase()) ||
    group.itemName?.toLowerCase().includes(searchTerm.toLowerCase()) ||
    group.lastPIC?.toLowerCase().includes(searchTerm.toLowerCase())
);

// Format location display
const formatLocation = (origin, destination) =\u003e {
    const capitalize = (str) =\u003e str.charAt(0).toUpperCase() + str.slice(1);
return `${capitalize(origin)} → ${capitalize(destination)}`;
    };

// Handle Remutation (Return to Warehouse)
const handleRemutation = async(group) =\u003e {
    const remainingAtDestination = group.totalMutated - group.totalRemutated;
if (remainingAtDestination \u003c = 0) {
    alert('Tidak ada barang yang perlu diremutasi');
    return;
}

if (!confirm(`Apakah Anda yakin ingin mengembalikan ${remainingAtDestination} unit ${group.itemName} ke Warehouse?`)) return;

try {
    // 1. Create Return Mutation Log
    const newMutation = {
        pengajuanId: group.pengajuanId,
        pengajuanNumber: group.pengajuanNumber,
        bcDocumentNumber: group.bcDocumentNumber,
        packageNumber: group.packageNumber,
        itemCode: group.itemCode,
        itemName: group.itemName,
        serialNumber: group.serialNumber,
        hsCode: group.hsCode,

        // Swap locations
        origin: group.destination,
        destination: 'Warehouse', // Returning to Warehouse

        totalStock: remainingAtDestination, // Stock at remote location
        mutatedQty: remainingAtDestination, // Moving ALL back
        remainingStock: 0, // Nothing left at remote

        date: new Date().toISOString().split('T')[0],
        time: new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }),
        pic: 'System (Auto Return)',
        remarks: `Remutasi Kembali ke Warehouse. Ref: ${group.pengajuanNumber}`,
        condition: 'Baik',
        uom: group.uom || 'pcs'
    };

    await addMutationLog(newMutation);

    // 2. Update Warehouse Inventory (Add Stock Back)
    await updateInventoryStock(
        group.itemCode,
        group.itemName,
        remainingAtDestination, // Positive quantity adds stock
        group.uom || 'pcs',
        'remutation',
        `REM-${Date.now()}`
    );

    alert('Berhasil melakukan remutasi barang ke Warehouse!');
    setSelectedGroup(null);
} catch (error) {
    console.error('Error processing remutation:', error);
    alert('Gagal melakukan remutasi: ' + error.message);
}
    };

// Export to CSV handler
const handleExportCSV = () =\u003e {
    const exportData = filteredLogs.map(group =\u003e({
        pengajuanNumber: group.pengajuanNumber,
        itemCode: group.itemCode,
        bcDocumentNumber: group.bcDocumentNumber,
        itemName: group.itemName,
        serialNumber: group.serialNumber,
        lastMutationDate: group.lastMutationDate,
        lastMutationTime: group.lastMutationTime,
        lastPIC: group.lastPIC,
        initialStock: group.initialStock,
        totalMutated: group.totalMutated,
        totalRemutated: group.totalRemutated,
        currentRemaining: group.currentRemaining,
        destination: group.destination,
        remarks: group.remarks
    }));

const columns = [
    { key: 'pengajuanNumber', header: 'No. Pengajuan' },
    { key: 'itemCode', header: 'Kode Barang' },
    { key: 'bcDocumentNumber', header: 'No. Dokumen' },
    { key: 'itemName', header: 'Nama Item' },
    { key: 'serialNumber', header: 'Serial Number' },
    { key: 'lastMutationDate', header: 'Tanggal' },
    { key: 'lastMutationTime', header: 'Jam' },
    { key: 'lastPIC', header: 'PIC' },
    { key: 'initialStock', header: 'Stok Awal' },
    { key: 'totalMutated', header: 'Total Mutasi' },
    { key: 'totalRemutated', header: 'Total Remutasi' },
    { key: 'currentRemaining', header: 'Sisa Stock' },
    { key: 'destination', header: 'Ke' },
    { key: 'remarks', header: 'Keterangan' }
];

exportToCSV(exportData, 'Pergerakan_Barang', columns);
    };

return (
\u003cdiv className =\"p-6 space-y-6\"\u003e
{/* Header */ }
\u003cdiv\u003e
\u003ch1 className =\"text-3xl font-bold gradient-text\"\u003ePergerakan Barang\u003c/h1\u003e
\u003cp className =\"text-silver-dark mt-1\"\u003eRiwayat Mutasi & Pergerakan Inventaris Gudang\u003c/p\u003e
\u003c / div\u003e

{/* Search & Stats */ }
\u003cdiv className =\"grid grid-cols-1 md:grid-cols-4 gap-4\"\u003e
{/* Search */ }
\u003cdiv className =\"md:col-span-2 glass-card p-4 rounded-lg\"\u003e
\u003cdiv className =\"relative\"\u003e
\u003cSearch className =\"absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-silver-dark\" /\u003e
\u003cinput
type =\"text\"
placeholder =\"Cari berdasarkan No. Pengajuan, Item, atau PIC...\"
value = { searchTerm }
onChange = {(e) =\u003e setSearchTerm(e.target.value)}
className =\"w-full pl-10 pr-4 py-2 bg-dark-surface border border-dark-border rounded-lg text-silver-light focus:border-accent-blue focus:outline-none\"
    /\u003e
\u003c / div\u003e
\u003c / div\u003e

{/* Stats */ }
\u003cdiv className =\"glass-card p-4 rounded-lg border border-accent-blue\"\u003e
\u003cp className =\"text-xs text-silver-dark\"\u003eTotal Item\u003c/p\u003e
\u003cp className =\"text-2xl font-bold text-accent-blue\"\u003e{groupedMutations.length}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv className =\"glass-card p-4 rounded-lg border border-accent-green\"\u003e
\u003cp className =\"text-xs text-silver-dark\"\u003eTotal Mutasi\u003c/p\u003e
\u003cp className =\"text-2xl font-bold text-accent-green\"\u003e
{ groupedMutations.reduce((sum, g) =\u003e sum + g.totalMutated, 0) }
\u003c / p\u003e
\u003c / div\u003e
\u003c / div\u003e

{/* Mutation Logs Table */ }
\u003cdiv className =\"glass-card rounded-lg overflow-hidden\"\u003e
\u003cdiv className =\"p-4 border-b border-dark-border\"\u003e
\u003cdiv className =\"flex items-center gap-2\"\u003e
\u003cPackage className =\"w-5 h-5 text-accent-purple\" /\u003e
\u003ch2 className =\"text-lg font-semibold text-silver-light\"\u003e
                            Riwayat Mutasi Barang
\u003c / h2\u003e
\u003cspan className =\"ml-auto text-sm text-silver-dark\"\u003e
{ filteredLogs.length } entri
\u003c / span\u003e
\u003cButton
onClick = { handleExportCSV }
variant =\"secondary\"
icon = { Download }
className =\"ml-2\"
\u003e
                            Export CSV
\u003c / Button\u003e
\u003c / div\u003e
\u003c / div\u003e

{
    filteredLogs.length === 0 ? (
    \u003cdiv className =\"p-12 text-center text-silver-dark\"\u003e
    \u003cPackage className =\"w-16 h-16 mx-auto mb-4 opacity-30\" /\u003e
    \u003cp className =\"text-lg\"\u003eBelum ada riwayat mutasi\u003c/p\u003e
    \u003cp className =\"text-sm mt-2\"\u003eMutasi barang akan muncul di sini setelah submit dari Inventaris Gudang\u003c/p\u003e
    \u003c / div\u003e
                ) : (
    \u003cdiv className =\"overflow-x-auto\"\u003e
    \u003ctable className =\"w-full\"\u003e
    \u003cthead className =\"bg-accent-purple/10\"\u003e
    \u003ctr\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eNo. Pengajuan\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eKode Barang\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eNo. Dokumen\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eNama Item / SN\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-silver whitespace-nowrap\"\u003eTanggal\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-silver whitespace-nowrap\"\u003eJam\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003ePIC\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-accent-blue whitespace-nowrap\"\u003eStok Awal\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-accent-orange whitespace-nowrap\"\u003eMutasi\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-accent-purple whitespace-nowrap\"\u003eRemutasi\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-center text-xs text-accent-green whitespace-nowrap\"\u003eSisa\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eLokasi\u003c/th\u003e
    \u003cth className =\"px-4 py-3 text-left text-xs text-silver whitespace-nowrap\"\u003eKeterangan\u003c/th\u003e
    \u003c / tr\u003e
    \u003c / thead\u003e
    \u003ctbody className =\"divide-y divide-dark-border\"\u003e
    {
        filteredLogs.map((group, idx) =\u003e(
            \u003ctr key = { idx } className =\"hover:bg-dark-surface/50 cursor-pointer\" onClick={() =\u003e setSelectedGroup(group)}\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver-light whitespace-nowrap\"\u003e{group.pengajuanNumber}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver-light whitespace-nowrap\"\u003e{group.itemCode || '-'}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver whitespace-nowrap\"\u003e{group.bcDocumentNumber}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver-light whitespace-nowrap\"\u003e
                                            { group.itemName } { group.serialNumber ? `(SN: ${group.serialNumber})` : '' }
            \u003c / td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver text-center whitespace-nowrap\"\u003e
                                            { group.lastMutationDate ? new Date(group.lastMutationDate).toLocaleDateString('id-ID') : '-' }
            \u003c / td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver text-center whitespace-nowrap\"\u003e{group.lastMutationTime || '-'}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver-light whitespace-nowrap\"\u003e{group.lastPIC || '-'}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-accent-blue text-center whitespace-nowrap\"\u003e{group.initialStock}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-accent-orange text-center whitespace-nowrap\"\u003e{group.totalMutated}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-accent-purple text-center whitespace-nowrap\"\u003e{group.totalRemutated}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-accent-green text-center whitespace-nowrap\"\u003e{group.currentRemaining}\u003c/td\u003e
            \u003ctd className =\"px-4 py-3 text-sm text-silver whitespace-nowrap\"\u003e
                                            {
                group.destination ? (\u003c\u003e
                \u003cspan className=\"capitalize\"\u003eWarehouse\u003c/span\u003e → \u003cspan className=\"capitalize\"\u003e{group.destination}\u003c/span\u003e
                \u003c/\u003e) : '-'}
    \u003c / td\u003e
    \u003ctd className =\"px-4 py-3 text-sm text-silver-dark max-w-xs truncate\"\u003e
    { group.remarks || '-' }
    \u003c / td\u003e
    \u003c / tr\u003e
                                ))
}
\u003c / tbody\u003e
\u003c / table\u003e
\u003c / div\u003e
                )}
\u003c / div\u003e

{/* Detail Modal */ }
{
    selectedGroup && (
    \u003cdiv className =\"fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-70 p-4\"\u003e
    \u003cdiv className =\"glass-card rounded-lg p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto\"\u003e
    \u003cdiv className =\"flex justify-between items-center mb-4\"\u003e
    \u003ch3 className =\"text-xl font-bold gradient-text\"\u003eDetail Mutasi\u003c/h3\u003e
    \u003cbutton onClick = {() =\u003e setSelectedGroup(null)
} className =\"p-2 hover:bg-dark-border rounded\"\u003e
\u003cspan className =\"text-silver\"\u003e✕\u003c/span\u003e
\u003c / button\u003e
\u003c / div\u003e

\u003cdiv className =\"grid grid-cols-2 gap-4\"\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eNo. Pengajuan\u003c/label\u003e
\u003cp className =\"text-sm text-silver-light\"\u003e{selectedGroup.pengajuanNumber}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eNo. Dokumen Pabean\u003c/label\u003e
\u003cp className =\"text-sm text-silver-light\"\u003e{selectedGroup.bcDocumentNumber}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv className =\"col-span-2\"\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eNama Item\u003c/label\u003e
\u003cp className =\"text-sm text-silver-light\"\u003e{selectedGroup.itemName}\u003c/p\u003e
\u003cp className =\"text-xs text-silver-dark mt-1\"\u003eSN: {selectedGroup.serialNumber}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eStok Awal (Inbound)\u003c/label\u003e
\u003cp className =\"text-lg font-bold text-accent-blue\"\u003e{selectedGroup.initialStock} {selectedGroup.uom}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eTotal Dimutasi\u003c/label\u003e
\u003cp className =\"text-lg font-bold text-accent-orange\"\u003e{selectedGroup.totalMutated} {selectedGroup.uom}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eTotal Diremutasi\u003c/label\u003e
\u003cp className =\"text-lg font-bold text-accent-purple\"\u003e{selectedGroup.totalRemutated} {selectedGroup.uom}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eSisa Stock\u003c/label\u003e
\u003cp className =\"text-lg font-bold text-accent-green\"\u003e{selectedGroup.currentRemaining} {selectedGroup.uom}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv className =\"col-span-2\"\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eLokasi Mutasi\u003c/label\u003e
\u003cp className =\"text-sm text-silver-light\"\u003eWarehouse → {selectedGroup.destination || 'N/A'}\u003c/p\u003e
\u003c / div\u003e
\u003cdiv className =\"col-span-2\"\u003e
\u003clabel className =\"text-xs text-silver-dark\"\u003eKeterangan\u003c/label\u003e
\u003cp className =\"text-sm text-silver-light\"\u003e{selectedGroup.remarks || 'Tidak ada keterangan'}\u003c/p\u003e
\u003c / div\u003e
\u003c / div\u003e

{/* Mutation Log Details */ }
{
    selectedGroup.mutations.length \u003e 0 && (
    \u003cdiv className =\"mt-6\"\u003e
    \u003ch4 className =\"text-sm font-semibold text-silver mb-2\"\u003eRiwayat Mutasi Keluar ({selectedGroup.mutations.length})\u003c/h4\u003e
    \u003cdiv className =\"space-y-2\"\u003e
    {
        selectedGroup.mutations.map((mut, idx) =\u003e(
            \u003cdiv key = { idx } className =\"p-3 bg-dark-surface rounded text-xs\"\u003e
            \u003cp\u003e\u003cstrong\u003eTanggal: \u003c / strong\u003e { new Date(mut.date).toLocaleDateString('id-ID') } { mut.time }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003eQty: \u003c / strong\u003e { mut.mutatedQty } { mut.uom }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003ePIC: \u003c / strong\u003e { mut.pic }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003eKe: \u003c / strong\u003e { mut.destination }\u003c / p\u003e
            \u003c / div\u003e
        ))
    }
    \u003c / div\u003e
    \u003c / div\u003e
                        )
}

{/* Remutation Log Details */ }
{
    selectedGroup.remutations.length \u003e 0 && (
    \u003cdiv className =\"mt-6\"\u003e
    \u003ch4 className =\"text-sm font-semibold text-silver mb-2\"\u003eRiwayat Remutasi Masuk ({selectedGroup.remutations.length})\u003c/h4\u003e
    \u003cdiv className =\"space-y-2\"\u003e
    {
        selectedGroup.remutations.map((rem, idx) =\u003e(
            \u003cdiv key = { idx } className =\"p-3 bg-dark-surface rounded text-xs\"\u003e
            \u003cp\u003e\u003cstrong\u003eTanggal: \u003c / strong\u003e { new Date(rem.date).toLocaleDateString('id-ID') } { rem.time }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003eQty: \u003c / strong\u003e { rem.mutatedQty } { rem.uom }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003ePIC: \u003c / strong\u003e { rem.pic }\u003c / p\u003e
            \u003cp\u003e\u003cstrong\u003eDari: \u003c / strong\u003e { rem.origin }\u003c / p\u003e
            \u003c / div\u003e
        ))
    }
    \u003c / div\u003e
    \u003c / div\u003e
                        )
}

\u003cdiv className =\"mt-6 flex justify-end gap-3\"\u003e
{/* Remutation Button - Only if there's remaining stock at destination */ }
{
    selectedGroup.destination &&
    (selectedGroup.totalMutated - selectedGroup.totalRemutated) \u003e 0 && (
    \u003cButton
    onClick = {() =\u003e handleRemutation(selectedGroup)
}
className =\"bg-accent-orange hover:bg-orange-600 text-white\"
\u003e
                                        Remutasi ke Warehouse
\u003c / Button\u003e
                                )}
\u003cButton variant =\"secondary\" onClick={() =\u003e setSelectedGroup(null)}\u003e
Tutup
\u003c / Button\u003e
\u003c / div\u003e
\u003c / div\u003e
\u003c / div\u003e
            )}
\u003c / div\u003e
    );
};

export default GoodsMovement;
